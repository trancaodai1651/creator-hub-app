{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Creator Hub",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run frontend:dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Creator Hub",
        "width": 1400,
        "height": 850,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/yt-dlp"
    ],
    "resources": [
      "resources/ffmpeg.exe",
      "resources/ffprobe.exe"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
