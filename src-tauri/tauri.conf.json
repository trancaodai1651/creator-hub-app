{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Creator Hub",
  "version": "1.1.1",
  "identifier": "com.creatorhub.app",
  "build": {
    "frontendDist": "../src/renderer/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Creator Hub",
        "width": 1600,
        "height": 1200,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' data: tauri: ipc: http://ipc.localhost; connect-src * tauri: ipc: http://ipc.localhost;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/yt-dlp"
    ],
    "resources": [
      "resources/ffmpeg.exe",
      "resources/ffprobe.exe"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
